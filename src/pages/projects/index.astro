---
import ProjectCard from '../../components/ProjectCard.astro';
import Layout from '../../layouts/Layout.astro';

const projects: Project[] = [
    {
        title: 'AtHome Lite',
        description: 'foo',
        slug: '/at-home-lite',
        cover: '',
    },{
        title: 'Continuum',
        description: 'bar',
        slug: '/continuum',
        cover: '',
    },{
        title: 'Roadside Assistance',
        description: 'baz',
        slug: '/roadside-assistance',
        cover: '',
    },{
        title: 'Coolfire',
        description: 'zip',
        slug: '/coolfire',
        cover: '',
    },{
        title: 'Mortgage',
        description: 'zap',
        slug: '/mortgage',
        cover: '',
    },
]
---

<Layout title="Brendan Bax | Projects">
    <main class="text-white">
        <ul>
            {projects.map((c, i) => (
                <li>
                    <ProjectCard project={c} index={i} />
                </li>
            ))}
          </ul>
    </main>
</Layout>